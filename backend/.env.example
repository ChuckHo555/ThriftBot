# ============================================================================
# ThriftBot — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. Add it to .gitignore.
# ============================================================================

# Anthropic API Key
# Get yours at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Supabase credentials
# Get these at: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# Optional overrides (defaults are fine for development)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# SUPABASE_BUCKET=item-images
# RATE_LIMIT_PER_HOUR=30
